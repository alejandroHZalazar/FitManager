@model FitManager.ViewModels.PlanViewModel
@{
    ViewData["Title"] = "Editar Plan";
    ViewData["BreadcrumbParent"] = "Planes";
}

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="fas fa-edit me-2 text-accent"></i>Editar Plan</h1>
        <p class="text-muted mb-0">@Model.Name</p>
    </div>
    <div class="page-actions">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i>Volver
        </a>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card fm-card">
            <div class="card-body">
                <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    @await Html.PartialAsync("_PlanFormFields", Model)
                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-accent">
                            <i class="fas fa-save me-2"></i>Guardar Cambios
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
