@model FitManager.ViewModels.ExerciseViewModel
@using FitManager.Models
@{
    ViewData["Title"] = "Nuevo Ejercicio";
    ViewData["BreadcrumbParent"] = "Biblioteca de Ejercicios";
}
<div class="page-header">
    <div><h1 class="page-title"><i class="fas fa-plus-circle me-2 text-accent"></i>Nuevo Ejercicio</h1></div>
    <div class="page-actions"><a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>Volver</a></div>
</div>
<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card fm-card">
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Nombre <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" placeholder="Ej. Press de Banca" required />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Descripción</label>
                        <textarea asp-for="Description" class="form-control" rows="2" placeholder="Descripción o instrucciones..."></textarea>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="MuscleGroup" class="form-label">Grupo Muscular</label>
                            <select asp-for="MuscleGroup" class="form-select">
                                <option value="1">Pecho</option>
                                <option value="2">Espalda</option>
                                <option value="3">Hombros</option>
                                <option value="4">Bíceps</option>
                                <option value="5">Tríceps</option>
                                <option value="7">Cuádriceps</option>
                                <option value="8">Femorales</option>
                                <option value="9">Pantorrillas</option>
                                <option value="10">Glúteos</option>
                                <option value="11">Abdominales</option>
                                <option value="12">Cardio</option>
                                <option value="13">Cuerpo Completo</option>
                                <option value="99">Otro</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ExerciseType" class="form-label">Tipo</label>
                            <select asp-for="ExerciseType" class="form-select">
                                <option value="1">Fuerza</option>
                                <option value="2">Cardio</option>
                                <option value="3">Flexibilidad</option>
                                <option value="4">Equilibrio</option>
                                <option value="5">Funcional</option>
                                <option value="99">Otro</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-4 form-check form-switch">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" />
                        <label asp-for="IsActive" class="form-check-label">Activo</label>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-accent"><i class="fas fa-save me-1"></i>Guardar</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
