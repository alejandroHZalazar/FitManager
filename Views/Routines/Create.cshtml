@model FitManager.ViewModels.RoutineEditViewModel
@{
    ViewData["Title"] = "Nueva Rutina";
    ViewData["BreadcrumbParent"] = "Rutinas";
}

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="fas fa-plus-circle me-2 text-accent"></i>Nueva Rutina</h1>
    </div>
    <div class="page-actions">
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>Volver</a>
    </div>
</div>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    @await Html.PartialAsync("_RoutineForm", Model)
</form>
