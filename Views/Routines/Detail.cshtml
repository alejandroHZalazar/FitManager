@model FitManager.ViewModels.RoutineDetailViewModel
@using FitManager.Models
@{
    ViewData["Title"] = Model.Routine.Name;
    ViewData["BreadcrumbParent"] = "Rutinas";
    var r = Model.Routine;
}

<div class="page-header">
    <div>
        <h1 class="page-title">
            <i class="fas fa-clipboard-list me-2 text-accent"></i>@r.Name
        </h1>
        <p class="text-muted mb-0">@Model.GoalLabel — @r.DurationWeeks sem. · @r.FrequencyPerWeek días/sem.</p>
    </div>
    <div class="page-actions d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>Volver</a>
        <a asp-action="Edit" asp-route-id="@r.Id" class="btn btn-outline-warning">
            <i class="fas fa-edit me-1"></i>Editar
        </a>
        <a asp-controller="MemberRoutines" asp-action="Assign" asp-route-memberId=""
           class="btn btn-outline-success">
            <i class="fas fa-user-plus me-1"></i>Asignar a Socio
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-4">
    <!-- ── Info General ─────────────────────────────────────────────────────── -->
    <div class="col-lg-4">
        <div class="card fm-card h-100">
            <div class="card-header">
                <h5 class="card-title mb-0"><i class="fas fa-info-circle me-2 text-accent"></i>Información General</h5>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-5 text-muted">Nombre</dt>
                    <dd class="col-7 fw-semibold">@r.Name</dd>

                    <dt class="col-5 text-muted">Objetivo</dt>
                    <dd class="col-7"><span class="badge bg-dark border border-secondary">@Model.GoalLabel</span></dd>

                    <dt class="col-5 text-muted">Duración</dt>
                    <dd class="col-7">@r.DurationWeeks semanas</dd>

                    <dt class="col-5 text-muted">Frecuencia</dt>
                    <dd class="col-7">@r.FrequencyPerWeek días / semana</dd>

                    <dt class="col-5 text-muted">Tipo</dt>
                    <dd class="col-7">
                        @if (r.IsGeneral)
                        {
                            <span class="badge bg-primary"><i class="fas fa-users me-1"></i>General</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark"><i class="fas fa-user me-1"></i>Personalizada</span>
                        }
                    </dd>

                    <dt class="col-5 text-muted">Estado</dt>
                    <dd class="col-7">
                        @if (r.IsActive)
                        {
                            <span class="badge bg-success"><i class="fas fa-circle me-1" style="font-size:.5rem;"></i>Activa</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary"><i class="fas fa-circle me-1" style="font-size:.5rem;"></i>Inactiva</span>
                        }
                    </dd>

                    <dt class="col-5 text-muted">Días</dt>
                    <dd class="col-7"><span class="badge bg-info">@r.Days.Count configurados</span></dd>
                </dl>

                @if (!string.IsNullOrWhiteSpace(r.Description))
                {
                    <hr class="border-secondary" />
                    <p class="text-muted small mb-0">@r.Description</p>
                }
            </div>
        </div>
    </div>

    <!-- ── Días y Ejercicios ─────────────────────────────────────────────────── -->
    <div class="col-lg-8">
        @if (!r.Days.Any())
        {
            <div class="card fm-card">
                <div class="card-body text-center text-muted py-5">
                    <i class="fas fa-calendar-times fa-3x mb-3 d-block opacity-40"></i>
                    <p class="mb-0">Esta rutina no tiene días configurados.</p>
                    <a asp-action="Edit" asp-route-id="@r.Id" class="btn btn-sm btn-outline-accent mt-3">
                        <i class="fas fa-edit me-1"></i>Agregar Días
                    </a>
                </div>
            </div>
        }
        else
        {
            @foreach (var day in r.Days.OrderBy(d => d.OrderIndex))
            {
                <div class="card fm-card mb-3">
                    <div class="card-header d-flex align-items-center gap-2"
                         style="background:rgba(255,255,255,.05);">
                        <span class="badge bg-accent">Día @day.DayNumber</span>
                        @if (!string.IsNullOrWhiteSpace(day.Name))
                        {
                            <span class="fw-semibold">@day.Name</span>
                        }
                        @if (day.IsRestDay)
                        {
                            <span class="badge bg-secondary ms-auto"><i class="fas fa-bed me-1"></i>Descanso</span>
                        }
                        else
                        {
                            <span class="badge bg-dark border border-secondary ms-auto text-muted small">
                                @day.Exercises.Count ejercicio(s)
                            </span>
                        }
                    </div>

                    @if (day.IsRestDay)
                    {
                        <div class="card-body text-center text-muted py-3">
                            <i class="fas fa-bed fa-lg me-2 opacity-40"></i>Día de descanso
                        </div>
                    }
                    else if (!day.Exercises.Any())
                    {
                        <div class="card-body text-muted small py-2 ps-3">
                            Sin ejercicios asignados.
                        </div>
                    }
                    else
                    {
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-sm fm-table mb-0">
                                    <thead>
                                        <tr>
                                            <th>#</th>
                                            <th>Ejercicio</th>
                                            <th class="text-center">Series</th>
                                            <th class="text-center">Reps</th>
                                            <th class="text-center">Peso (kg)</th>
                                            <th class="text-center">Desc. (s)</th>
                                            <th>Notas</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var ex in day.Exercises.OrderBy(e => e.OrderIndex))
                                        {
                                            <tr>
                                                <td class="text-muted small">@(day.Exercises.OrderBy(e=>e.OrderIndex).ToList().IndexOf(ex)+1)</td>
                                                <td class="fw-semibold">@ex.Exercise?.Name</td>
                                                <td class="text-center">@ex.Sets</td>
                                                <td class="text-center">@ex.Reps</td>
                                                <td class="text-center">@(ex.Weight.HasValue ? ex.Weight.Value.ToString("0.##") + " kg" : "—")</td>
                                                <td class="text-center">@(ex.RestSeconds.HasValue ? ex.RestSeconds.Value + "s" : "—")</td>
                                                <td class="text-muted small">@ex.Notes</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }
                </div>
            }
        }
    </div>
</div>
