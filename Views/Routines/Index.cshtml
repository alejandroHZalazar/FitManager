@model List<FitManager.ViewModels.RoutineListViewModel>
@{
    ViewData["Title"] = "Gestión de Rutinas";
    ViewData["BreadcrumbParent"] = "Rutinas";
}

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="fas fa-clipboard-list me-2 text-accent"></i>Gestión de Rutinas</h1>
        <p class="text-muted mb-0">@Model.Count rutina(s) registradas</p>
    </div>
    <div class="page-actions d-flex gap-2">
        <a asp-action="Create" class="btn btn-accent"><i class="fas fa-plus me-1"></i>Nueva Rutina</a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card fm-card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table id="routinesTable" class="table table-hover fm-table mb-0">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Objetivo</th>
                        <th class="text-center">Duración</th>
                        <th class="text-center">Frec./sem.</th>
                        <th class="text-center">Días</th>
                        <th class="text-center">Tipo</th>
                        <th class="text-center">Asignados</th>
                        <th class="text-center">Estado</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@r.Name</td>
                            <td><span class="badge bg-dark border border-secondary">@r.GoalLabel</span></td>
                            <td class="text-center">@r.DurationWeeks sem.</td>
                            <td class="text-center">@r.FrequencyPerWeek días</td>
                            <td class="text-center">
                                <span class="badge @(r.DayCount > 0 ? "bg-info" : "bg-dark border border-secondary")">@r.DayCount</span>
                            </td>
                            <td class="text-center">
                                @if (r.IsGeneral)
                                {
                                    <span class="badge bg-primary">General</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Personalizada</span>
                                }
                            </td>
                            <td class="text-center">
                                <span class="badge @(r.AssignedCount > 0 ? "bg-success" : "bg-dark border border-secondary")">@r.AssignedCount</span>
                            </td>
                            <td class="text-center">
                                @if (r.IsActive)
                                {
                                    <span class="badge badge-status bg-success"><i class="fas fa-circle me-1" style="font-size:.5rem;"></i>Activa</span>
                                }
                                else
                                {
                                    <span class="badge badge-status bg-secondary"><i class="fas fa-circle me-1" style="font-size:.5rem;"></i>Inactiva</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex justify-content-center gap-1">
                                    <a asp-action="Detail" asp-route-id="@r.Id" class="btn btn-sm btn-icon btn-outline-info" title="Ver detalle">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@r.Id" class="btn btn-sm btn-icon btn-outline-warning" title="Editar">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a asp-controller="MemberRoutines" asp-action="Assign" asp-route-memberId=""
                                       class="btn btn-sm btn-icon btn-outline-success" title="Asignar a socio">
                                        <i class="fas fa-user-plus"></i>
                                    </a>
                                    <form asp-action="ToggleActive" asp-route-id="@r.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-icon @(r.IsActive ? "btn-outline-secondary" : "btn-outline-success")"
                                                title="@(r.IsActive ? "Desactivar" : "Activar")">
                                            <i class="fas @(r.IsActive ? "fa-toggle-off" : "fa-toggle-on")"></i>
                                        </button>
                                    </form>
                                    @if (r.AssignedCount == 0)
                                    {
                                        <form asp-action="Delete" asp-route-id="@r.Id" method="post" class="d-inline delete-form">
                                            @Html.AntiForgeryToken()
                                            <button type="button" class="btn btn-sm btn-icon btn-outline-danger btn-delete" data-name="@r.Name">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
$(document).ready(function () {
    $('#routinesTable').DataTable({
        language: dtSpanish, pageLength: 25, order: [[0, 'asc']],
        columnDefs: [{ orderable: false, targets: [8] }]
    });
    $(document).on('click', '.btn-delete', function () {
        const form = $(this).closest('.delete-form');
        const name = $(this).data('name');
        Swal.fire({
            title: '¿Eliminar rutina?',
            html: `¿Eliminás la rutina <strong>${name}</strong>? Se eliminarán todos sus días y ejercicios.`,
            icon: 'warning', showCancelButton: true,
            confirmButtonColor: '#dc3545', cancelButtonColor: '#6c757d',
            confirmButtonText: '<i class="fas fa-trash me-1"></i>Sí, eliminar',
            cancelButtonText: 'Cancelar', background: '#1a1d27', color: '#e0e0e0'
        }).then(r => { if (r.isConfirmed) form.submit(); });
    });
});
</script>
}
