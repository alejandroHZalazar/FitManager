@model FitManager.ViewModels.ActiveMembersReportViewModel
@{
    ViewData["Title"] = "Socios Activos";
    ViewData["BreadcrumbParent"] = "Reportes";
}

@await Html.PartialAsync("_ReportCompanyHeader", (FitManager.Models.CompanySettings?)ViewBag.Company)

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="fas fa-users me-2 text-primary"></i>Socios Activos</h1>
        <p class="text-muted mb-0">@Model.Filter.PresetLabel</p>
    </div>
    <a asp-action="Index" asp-controller="Reports" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-1"></i>Reportes
    </a>
</div>

@await Html.PartialAsync("_FilterBar", Model.Filter)

@* ── KPIs ─────────────────────────────────────────────────────────────────── *@
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-lg">
        <div class="stat-card stat-primary">
            <div class="stat-icon"><i class="fas fa-users"></i></div>
            <div>
                <div class="stat-value">@Model.TotalActive</div>
                <div class="stat-label">Socios activos</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg">
        <div class="stat-card stat-success">
            <div class="stat-icon"><i class="fas fa-user-plus"></i></div>
            <div>
                <div class="stat-value">@Model.NewInPeriod</div>
                <div class="stat-label">Nuevos en el período</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg">
        <div class="stat-card stat-accent">
            <div class="stat-icon"><i class="fas fa-id-card"></i></div>
            <div>
                <div class="stat-value">@Model.WithActivePlan</div>
                <div class="stat-label">Con plan vigente</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg">
        <div class="stat-card stat-warning">
            <div class="stat-icon"><i class="fas fa-user-times"></i></div>
            <div>
                <div class="stat-value">@Model.WithoutActivePlan</div>
                <div class="stat-label">Sin plan activo</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg">
        <div class="stat-card" style="border-color:rgba(220,53,69,0.4)">
            <div class="stat-icon" style="background:rgba(220,53,69,0.15);color:#dc3545"><i class="fas fa-calendar-times"></i></div>
            <div>
                <div class="stat-value">@Model.ExpiringIn5Days</div>
                <div class="stat-label">Vencen en 5 días</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    @* ── Gráfico por plan ─────────────────────────────────────────────────── *@
    <div class="col-lg-4">
        <div class="fm-card h-100">
            <div class="card-header"><h6 class="card-title mb-0"><i class="fas fa-chart-pie me-2 text-accent"></i>Distribución por plan</h6></div>
            <div class="card-body">
                @if (Model.ByPlan.Any())
                {
                    <canvas id="planChart" height="200"></canvas>
                    <div class="mt-3">
                        @{ var colors = new[]{"#ff6b35","#0d6efd","#198754","#ffc107","#0dcaf0","#6f42c1"}; var ci = 0; }
                        @foreach (var p in Model.ByPlan)
                        {
                            var col = colors[ci++ % colors.Length];
                            <div class="d-flex justify-content-between small mb-1">
                                <span><span class="badge me-1" style="background:@col">●</span>@p.PlanName</span>
                                <span class="text-muted">@p.Count (@p.Percent%)</span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted text-center py-4">Sin datos de planes.</p>
                }
            </div>
        </div>
    </div>

    @* ── Barra de progreso sin plan ───────────────────────────────────────── *@
    <div class="col-lg-8">
        <div class="fm-card h-100">
            <div class="card-header"><h6 class="card-title mb-0"><i class="fas fa-info-circle me-2 text-accent"></i>Estado de planes</h6></div>
            <div class="card-body">
                @{
                    var pct = Model.TotalActive > 0 ? (double)Model.WithActivePlan / Model.TotalActive * 100 : 0;
                }
                <div class="mb-4">
                    <div class="d-flex justify-content-between mb-1">
                        <span class="small">Socios con plan vigente</span>
                        <span class="small fw-semibold">@Model.WithActivePlan / @Model.TotalActive (@pct.ToString("F0")%)</span>
                    </div>
                    <div class="progress" style="height:12px;background:rgba(255,255,255,0.07)">
                        <div class="progress-bar bg-success" style="width:@pct.ToString("F0")%"></div>
                    </div>
                </div>
                @foreach (var p in Model.ByPlan)
                {
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="small">@p.PlanName</span>
                            <span class="small text-muted">@p.Count socios (@p.Percent%)</span>
                        </div>
                        <div class="progress" style="height:8px;background:rgba(255,255,255,0.07)">
                            <div class="progress-bar" style="width:@p.Percent%;background:var(--fm-accent)"></div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@* ── Tabla de socios ──────────────────────────────────────────────────────── *@
<div class="fm-card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="card-title mb-0"><i class="fas fa-list me-2 text-accent"></i>Listado de socios activos</h6>
        <span class="badge bg-secondary">@Model.Members.Count</span>
    </div>
    <div class="card-body p-0">
        <table class="table table-dark table-hover mb-0" id="membersTable">
            <thead>
                <tr>
                    <th>Socio</th>
                    <th>Nº</th>
                    <th>Plan vigente</th>
                    <th>Vence</th>
                    <th>Días restantes</th>
                    <th>Alta</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var m in Model.Members)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                @if (!string.IsNullOrEmpty(m.PhotoPath))
                                {
                                    <img src="@m.PhotoPath" class="member-avatar" />
                                }
                                else
                                {
                                    <div class="member-avatar-placeholder"><i class="fas fa-user"></i></div>
                                }
                                <span>
                                    @m.FullName
                                    @if (m.IsNew) { <span class="badge bg-success ms-1 small">Nuevo</span> }
                                </span>
                            </div>
                        </td>
                        <td><small class="text-muted">@m.MemberNumber</small></td>
                        <td>
                            @if (m.PlanName != null) { @m.PlanName }
                            else { <span class="text-muted small">Sin plan</span> }
                        </td>
                        <td>@(m.PlanEndDate.HasValue ? m.PlanEndDate.Value.ToString("dd/MM/yyyy") : "–")</td>
                        <td>
                            @if (m.DaysLeft.HasValue)
                            {
                                var daysClass = m.DaysLeft.Value <= 3 ? "danger" : m.DaysLeft.Value <= 7 ? "warning" : "success";
                                <span class="badge bg-@daysClass">@m.DaysLeft días</span>
                            }
                            else
                            {
                                <span class="text-muted small">–</span>
                            }
                        </td>
                        <td><small class="text-muted">@m.JoinDate.ToString("dd/MM/yyyy")</small></td>
                        <td>
                            <a asp-controller="Members" asp-action="Detail" asp-route-id="@m.Id"
                               class="btn btn-icon btn-sm btn-outline-secondary" title="Ver socio">
                                <i class="fas fa-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
Chart.defaults.color = '#8892a4';
@if (Model.ByPlan.Any())
{
    var cols = new[]{"#ff6b35","#0d6efd","#198754","#ffc107","#0dcaf0","#6f42c1"};
    <text>
    new Chart(document.getElementById('planChart'), {
        type: 'doughnut',
        data: {
            labels: [@Html.Raw(string.Join(",", Model.ByPlan.Select(p => $"'{p.PlanName}'")))],
            datasets: [{
                data: [@string.Join(",", Model.ByPlan.Select(p => p.Count))],
                backgroundColor: [@Html.Raw(string.Join(",", Model.ByPlan.Select((p,i) => $"'{cols[i % cols.Length]}'")))],
                borderWidth: 2, borderColor: '#1a1d27'
            }]
        },
        options: { responsive: true, cutout: '60%', plugins: { legend: { display: false } } }
    });
    </text>
}
if (typeof $.fn.DataTable !== 'undefined') {
    $('#membersTable').DataTable({
        language: { url: 'https://cdn.datatables.net/plug-ins/1.13.4/i18n/es-ES.json' },
        pageLength: 25
    });
}
</script>
}
