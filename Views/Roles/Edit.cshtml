@model FitManager.ViewModels.RoleViewModel
@{
    ViewData["Title"] = "Editar Rol";
    ViewData["BreadcrumbParent"] = "Roles";
}
<div class="page-header">
    <h1 class="page-title"><i class="fas fa-edit me-2 text-accent"></i>Editar Rol</h1>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-2"></i>Volver</a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card fm-card">
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label required-label"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="Description" class="form-label"></label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    </div>
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                    <button type="submit" class="btn btn-accent w-100">
                        <i class="fas fa-save me-2"></i>Guardar Cambios
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
@section Scripts { @await Html.PartialAsync("_ValidationScripts") }
