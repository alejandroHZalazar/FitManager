@model FitManager.ViewModels.MenuPermissionViewModel
@{
    ViewData["Title"] = $"Permisos de Menú — {Model.RoleName}";
    ViewData["BreadcrumbParent"] = "Roles";
}

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="fas fa-bars me-2 text-accent"></i>Permisos de Menú</h1>
        <p class="text-muted mb-0">Rol: <strong>@Model.RoleName</strong></p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-2"></i>Volver</a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card fm-card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0"><i class="fas fa-toggle-on me-2 text-accent"></i>Elementos del Menú</h5>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-sm btn-outline-success" id="selectAll">
                        <i class="fas fa-check-double me-1"></i>Todos
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-secondary" id="selectNone">
                        <i class="fas fa-times me-1"></i>Ninguno
                    </button>
                </div>
            </div>
            <div class="card-body">
                <form asp-action="SaveMenuPermissions" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="roleId" value="@Model.RoleId" />

                    @{
                        var parentItems = Model.Items.Where(i => i.ParentId == null).ToList();
                        var childItems = Model.Items.Where(i => i.ParentId != null).ToList();
                    }

                    <div class="menu-permission-list">
                        @foreach (var item in parentItems)
                        {
                            var children = childItems.Where(c => c.ParentId == item.MenuItemId).ToList();
                            <div class="menu-permission-group">
                                <div class="menu-permission-item parent-item">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input perm-check" type="checkbox"
                                               name="enabledItems" value="@item.MenuItemId"
                                               id="perm-@item.MenuItemId"
                                               @(item.IsEnabled ? "checked" : "")
                                               data-parent="true" />
                                        <label class="form-check-label d-flex align-items-center gap-2"
                                               for="perm-@item.MenuItemId">
                                            <i class="@item.Icon text-accent"></i>
                                            <span class="fw-semibold">@item.Name</span>
                                        </label>
                                    </div>
                                </div>

                                @if (children.Any())
                                {
                                    <div class="menu-permission-children">
                                        @foreach (var child in children)
                                        {
                                            <div class="menu-permission-item child-item">
                                                <div class="form-check form-switch">
                                                    <input class="form-check-input perm-check" type="checkbox"
                                                           name="enabledItems" value="@child.MenuItemId"
                                                           id="perm-@child.MenuItemId"
                                                           @(child.IsEnabled ? "checked" : "")
                                                           data-parent-id="@item.MenuItemId" />
                                                    <label class="form-check-label d-flex align-items-center gap-2"
                                                           for="perm-@child.MenuItemId">
                                                        <i class="@child.Icon text-muted"></i>
                                                        <span>@child.Name</span>
                                                    </label>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-accent flex-fill">
                            <i class="fas fa-save me-2"></i>Guardar Permisos
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.getElementById('selectAll')?.addEventListener('click', function () {
    document.querySelectorAll('.perm-check').forEach(cb => cb.checked = true);
});
document.getElementById('selectNone')?.addEventListener('click', function () {
    document.querySelectorAll('.perm-check').forEach(cb => cb.checked = false);
});
// Enabling a child auto-enables parent
document.querySelectorAll('.perm-check[data-parent-id]').forEach(cb => {
    cb.addEventListener('change', function () {
        if (this.checked) {
            var parentId = this.dataset.parentId;
            var parent = document.getElementById('perm-' + parentId);
            if (parent) parent.checked = true;
        }
    });
});
</script>
}
