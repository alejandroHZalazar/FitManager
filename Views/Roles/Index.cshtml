@model List<FitManager.ViewModels.RoleViewModel>
@{
    ViewData["Title"] = "Roles";
    ViewData["BreadcrumbParent"] = "Administración";
}

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="fas fa-shield-alt me-2 text-accent"></i>Gestión de Roles</h1>
        <p class="text-muted mb-0">@Model.Count roles configurados</p>
    </div>
    <div class="page-actions">
        <a asp-action="Create" class="btn btn-accent">
            <i class="fas fa-plus me-2"></i>Nuevo Rol
        </a>
    </div>
</div>

<div class="row g-4">
    @foreach (var role in Model)
    {
        <div class="col-md-6 col-xl-4">
            <div class="card fm-card role-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="d-flex align-items-center gap-3">
                            <div class="role-icon">
                                <i class="fas fa-shield-alt"></i>
                            </div>
                            <div>
                                <h5 class="mb-0 fw-bold">@role.Name</h5>
                                @if (role.IsSystem)
                                {
                                    <span class="badge bg-info text-dark small">Sistema</span>
                                }
                            </div>
                        </div>
                        <span class="badge bg-dark border border-secondary fs-6 px-3">
                            <i class="fas fa-users me-1"></i>@role.UserCount
                        </span>
                    </div>

                    @if (!string.IsNullOrEmpty(role.Description))
                    {
                        <p class="text-muted small mb-3">@role.Description</p>
                    }

                    <div class="d-flex gap-2 flex-wrap">
                        <a asp-action="MenuPermissions" asp-route-id="@role.Id"
                           class="btn btn-sm btn-outline-accent">
                            <i class="fas fa-bars me-1"></i>Permisos Menú
                        </a>
                        @if (!role.IsSystem)
                        {
                            <a asp-action="Edit" asp-route-id="@role.Id"
                               class="btn btn-sm btn-outline-warning">
                                <i class="fas fa-edit me-1"></i>Editar
                            </a>
                            <form asp-action="Delete" asp-route-id="@role.Id" method="post"
                                  class="d-inline confirm-delete-form">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-outline-danger">
                                    <i class="fas fa-trash me-1"></i>Eliminar
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
<script>
$(document).ready(function () { confirmDeleteForms(); });
</script>
}
