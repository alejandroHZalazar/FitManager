@using FitManager.Services
@inject IMenuService MenuService
@inject ICompanyService CompanyService
@{
    var userRoles = User.Claims
        .Where(c => c.Type == System.Security.Claims.ClaimTypes.Role)
        .Select(c => c.Value)
        .ToList();
    var menuItems = User.Identity?.IsAuthenticated == true
        ? await MenuService.GetMenuForRolesAsync(userRoles)
        : new List<FitManager.Models.MenuItem>();

    var company = User.Identity?.IsAuthenticated == true
        ? await CompanyService.GetAsync()
        : null;

    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}
<!DOCTYPE html>
<html lang="es" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — @(company?.Name ?? "FitManager")</title>

    <!-- Bootstrap 5 dark -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <!-- DataTables -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css" />
    <!-- SweetAlert2 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" />
    <!-- Custom -->
    <link rel="stylesheet" href="~/css/fitmanager.css" asp-append-version="true" />
</head>
<body>

@if (User.Identity?.IsAuthenticated == true)
{
    <!-- ── Sidebar ──────────────────────────────────────────────── -->
    <nav id="sidebar" class="sidebar">
        <div class="sidebar-header">
            <a class="sidebar-brand" href="/">
                @if (!string.IsNullOrEmpty(company?.LogoPath))
                {
                    <img src="/@company.LogoPath" alt="Logo" class="sidebar-logo me-2"
                         style="height:32px;width:32px;object-fit:contain;border-radius:4px;flex-shrink:0;" />
                }
                else
                {
                    <i class="fas fa-dumbbell me-2"></i>
                }
                <span class="brand-text">@(company?.Name ?? "FitManager")</span>
            </a>
            <button class="btn btn-sm btn-icon sidebar-toggle d-lg-none" id="sidebarClose">
                <i class="fas fa-times"></i>
            </button>
        </div>

        <div class="sidebar-user">
            <div class="user-avatar">
                <i class="fas fa-user-circle fa-2x"></i>
            </div>
            <div class="user-info">
                <span class="user-name">@User.Identity.Name</span>
                <span class="user-role">@string.Join(", ", userRoles)</span>
            </div>
        </div>

        <ul class="sidebar-nav">
            @foreach (var item in menuItems)
            {
                var isParentActive = item.Children.Any(c =>
                    c.Controller != null && c.Controller.Equals(currentController, StringComparison.OrdinalIgnoreCase));
                var isDirectActive = item.Controller != null &&
                    item.Controller.Equals(currentController, StringComparison.OrdinalIgnoreCase) &&
                    (item.Action == null || item.Action.Equals(currentAction, StringComparison.OrdinalIgnoreCase));

                if (item.Children.Any())
                {
                    <li class="nav-item has-submenu @(isParentActive ? "open" : "")">
                        <a class="nav-link @(isParentActive ? "active" : "")" href="#submenu-@item.Id"
                           data-bs-toggle="collapse" aria-expanded="@(isParentActive ? "true" : "false")">
                            <i class="nav-icon @item.Icon"></i>
                            <span class="nav-text">@item.Name</span>
                            <i class="nav-arrow fas fa-chevron-right ms-auto"></i>
                        </a>
                        <ul class="collapse submenu @(isParentActive ? "show" : "")" id="submenu-@item.Id">
                            @foreach (var child in item.Children)
                            {
                                var childActive = child.Controller != null &&
                                    child.Controller.Equals(currentController, StringComparison.OrdinalIgnoreCase) &&
                                    (child.Action == null || child.Action.Equals(currentAction, StringComparison.OrdinalIgnoreCase));

                                var childUrl = child.Controller != null
                                    ? Url.Action(child.Action ?? "Index", child.Controller)
                                    : child.Url ?? "#";
                                <li>
                                    <a class="nav-link @(childActive ? "active" : "")" href="@childUrl">
                                        <i class="nav-icon @child.Icon"></i>
                                        <span class="nav-text">@child.Name</span>
                                    </a>
                                </li>
                            }
                        </ul>
                    </li>
                }
                else
                {
                    var url = item.Controller != null
                        ? Url.Action(item.Action ?? "Index", item.Controller)
                        : item.Url ?? "#";
                    <li class="nav-item">
                        <a class="nav-link @(isDirectActive ? "active" : "")" href="@url">
                            <i class="nav-icon @item.Icon"></i>
                            <span class="nav-text">@item.Name</span>
                        </a>
                    </li>
                }
            }
        </ul>

        <div class="sidebar-footer">
            <form asp-controller="Account" asp-action="Logout" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="nav-link w-100 border-0 bg-transparent text-start">
                    <i class="nav-icon fas fa-sign-out-alt"></i>
                    <span class="nav-text">Cerrar Sesión</span>
                </button>
            </form>
        </div>
    </nav>

    <!-- ── Overlay (mobile) ─────────────────────────────────────── -->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <!-- ── Main wrapper ─────────────────────────────────────────── -->
    <div class="main-wrapper" id="mainWrapper">
        <!-- Top Navbar -->
        <header class="topbar">
            <button class="btn btn-icon topbar-toggle" id="sidebarToggle" title="Toggle sidebar">
                <i class="fas fa-bars"></i>
            </button>

            <nav aria-label="breadcrumb" class="ms-3 d-none d-sm-flex align-items-center">
                @if (ViewData["BreadcrumbParent"] != null)
                {
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item"><a href="/">Dashboard</a></li>
                        <li class="breadcrumb-item"><a href="#">@ViewData["BreadcrumbParent"]</a></li>
                        <li class="breadcrumb-item active">@ViewData["Title"]</li>
                    </ol>
                }
                else
                {
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item"><a href="/">Dashboard</a></li>
                        <li class="breadcrumb-item active">@ViewData["Title"]</li>
                    </ol>
                }
            </nav>

            <div class="ms-auto d-flex align-items-center gap-2">
                <span class="text-muted d-none d-md-inline small">
                    <i class="fas fa-calendar-alt me-1"></i>@DateTime.Today.ToString("dd/MM/yyyy")
                </span>
                <div class="topbar-user">
                    <i class="fas fa-user-circle me-1"></i>@User.Identity.Name
                </div>
            </div>
        </header>

        <!-- Page Content -->
        <main class="page-content">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-2 mb-3" role="alert">
                    <i class="fas fa-check-circle"></i>
                    <span>@TempData["Success"]</span>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center gap-2 mb-3" role="alert">
                    <i class="fas fa-exclamation-triangle"></i>
                    <span>@TempData["Error"]</span>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @RenderBody()
        </main>

        <footer class="page-footer">
            <span class="text-muted small">
                &copy; @DateTime.Today.Year @(company?.Name ?? "FitManager") — Sistema de Gestión de Gimnasios
            </span>
        </footer>
    </div>
}
else
{
    @RenderBody()
}

<!-- Scripts -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
<script src="~/js/fitmanager.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
