@model MemberViewModel
@{
    ViewData["Title"] = "Nuevo Socio";
    ViewData["BreadcrumbParent"] = "Socios";
}

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="fas fa-user-plus me-2 text-accent"></i>Nuevo Socio</h1>
        <p class="text-muted mb-0">Complete los datos del nuevo socio</p>
    </div>
    <div class="page-actions">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>Volver
        </a>
    </div>
</div>

<form asp-action="Create" method="post" enctype="multipart/form-data" id="memberForm">
    @Html.AntiForgeryToken()
    <div class="row g-4">

        <!-- Left: Personal data -->
        <div class="col-lg-8">
            <div class="card fm-card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0"><i class="fas fa-id-card me-2 text-accent"></i>Datos Personales</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-sm-6">
                            <label asp-for="FirstName" class="form-label required-label"></label>
                            <input asp-for="FirstName" class="form-control" placeholder="Nombre" />
                            <span asp-validation-for="FirstName" class="text-danger small"></span>
                        </div>
                        <div class="col-sm-6">
                            <label asp-for="LastName" class="form-label required-label"></label>
                            <input asp-for="LastName" class="form-control" placeholder="Apellido" />
                            <span asp-validation-for="LastName" class="text-danger small"></span>
                        </div>
                        <div class="col-sm-6">
                            <label asp-for="DNI" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-id-badge"></i></span>
                                <input asp-for="DNI" class="form-control" placeholder="Nº de documento" />
                            </div>
                            <span asp-validation-for="DNI" class="text-danger small"></span>
                        </div>
                        <div class="col-sm-6">
                            <label asp-for="DateOfBirth" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-birthday-cake"></i></span>
                                <input asp-for="DateOfBirth" class="form-control" type="date" />
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <label asp-for="Email" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                                <input asp-for="Email" class="form-control" placeholder="correo@ejemplo.com" />
                            </div>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-sm-6">
                            <label asp-for="Phone" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-phone"></i></span>
                                <input asp-for="Phone" class="form-control" placeholder="+54 9 11 0000-0000" />
                            </div>
                        </div>
                        <div class="col-12">
                            <label asp-for="Address" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-map-marker-alt"></i></span>
                                <input asp-for="Address" class="form-control" placeholder="Dirección completa" />
                            </div>
                        </div>
                        <div class="col-12">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes" class="form-control" rows="3"
                                      placeholder="Observaciones, condiciones médicas, etc."></textarea>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Membership -->
            <div class="card fm-card">
                <div class="card-header">
                    <h5 class="card-title mb-0"><i class="fas fa-calendar-alt me-2 text-accent"></i>Membresía</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-sm-4">
                            <label asp-for="Status" class="form-label"></label>
                            <select asp-for="Status" class="form-select">
                                <option value="1">Activo</option>
                                <option value="0">Inactivo</option>
                            </select>
                        </div>
                        <div class="col-sm-4">
                            <label asp-for="MembershipStartDate" class="form-label"></label>
                            <input asp-for="MembershipStartDate" class="form-control" type="date" />
                        </div>
                        <div class="col-sm-4">
                            <label asp-for="MembershipEndDate" class="form-label"></label>
                            <input asp-for="MembershipEndDate" class="form-control" type="date" />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right: Photo & submit -->
        <div class="col-lg-4">
            <div class="card fm-card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0"><i class="fas fa-camera me-2 text-accent"></i>Foto del Socio</h5>
                </div>
                <div class="card-body text-center">
                    <div class="photo-preview mb-3" id="photoPreview">
                        <i class="fas fa-user fa-4x text-muted"></i>
                    </div>
                    <label class="btn btn-outline-secondary w-100" for="PhotoFile">
                        <i class="fas fa-upload me-2"></i>Seleccionar Foto
                    </label>
                    <input asp-for="PhotoFile" class="d-none" id="PhotoFile"
                           accept="image/jpeg,image/png,image/webp" />
                    <small class="text-muted d-block mt-2">JPG, PNG o WebP — máx. 2MB</small>
                </div>
            </div>

            <div class="card fm-card">
                <div class="card-body">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                    <button type="submit" class="btn btn-accent w-100 btn-lg mb-2">
                        <i class="fas fa-save me-2"></i>Guardar Socio
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary w-100">
                        <i class="fas fa-times me-2"></i>Cancelar
                    </a>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @await Html.PartialAsync("_ValidationScripts")
    <script>
        document.getElementById('PhotoFile')?.addEventListener('change', function () {
            previewPhoto(this, 'photoPreview');
        });
    </script>
}
