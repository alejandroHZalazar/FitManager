@model MemberPaymentsViewModel
@{
    ViewData["Title"] = $"Pagos — {Model.Member.FullName}";
    ViewData["BreadcrumbParent"] = "Socios";
}

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="fas fa-credit-card me-2 text-accent"></i>Historial de Pagos</h1>
        <p class="text-muted mb-0">
            <span class="badge bg-dark border border-secondary me-2">@Model.Member.MemberNumber</span>
            @Model.Member.FullName
        </p>
    </div>
    <div class="page-actions d-flex gap-2">
        <a asp-action="Details" asp-route-id="@Model.Member.Id" class="btn btn-outline-info">
            <i class="fas fa-user me-2"></i>Ver Perfil
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>Volver
        </a>
    </div>
</div>

<!-- Summary cards -->
<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="stat-card stat-success">
            <div class="stat-icon"><i class="fas fa-check-circle"></i></div>
            <div class="stat-info">
                <div class="stat-value">$@Model.TotalPaid.ToString("N2")</div>
                <div class="stat-label">Total Pagado</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card stat-warning">
            <div class="stat-icon"><i class="fas fa-clock"></i></div>
            <div class="stat-info">
                <div class="stat-value">$@Model.TotalPending.ToString("N2")</div>
                <div class="stat-label">Pendiente</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card stat-primary">
            <div class="stat-icon"><i class="fas fa-list"></i></div>
            <div class="stat-info">
                <div class="stat-value">@Model.Payments.Count</div>
                <div class="stat-label">Transacciones</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card stat-accent">
            <div class="stat-icon"><i class="fas fa-dollar-sign"></i></div>
            <div class="stat-info">
                <div class="stat-value">$@((Model.TotalPaid + Model.TotalPending).ToString("N2"))</div>
                <div class="stat-label">Total General</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Payment list -->
    <div class="col-lg-8">
        <div class="card fm-card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0"><i class="fas fa-history me-2 text-accent"></i>Historial</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table id="paymentsTable" class="table table-hover table-dark align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Fecha</th>
                                <th>Descripción</th>
                                <th>Método</th>
                                <th>Monto</th>
                                <th>Vencimiento</th>
                                <th>Estado</th>
                                @if (User.IsInRole("Administrador"))
                                {
                                    <th width="60"></th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in Model.Payments)
                            {
                                <tr>
                                    <td>@p.PaymentDate.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        @(p.Description ?? "Cuota mensual")
                                        @if (!string.IsNullOrEmpty(p.ReceiptNumber))
                                        {
                                            <br /><small class="text-muted">Recibo: @p.ReceiptNumber</small>
                                        }
                                    </td>
                                    <td>
                                        @{
                                            var (methodIcon, methodText) = p.Method switch
                                            {
                                                FitManager.Models.PaymentMethod.Cash => ("fas fa-money-bill-wave", "Efectivo"),
                                                FitManager.Models.PaymentMethod.Card => ("fas fa-credit-card", "Tarjeta"),
                                                FitManager.Models.PaymentMethod.Transfer => ("fas fa-exchange-alt", "Transferencia"),
                                                _ => ("fas fa-question", "Otro")
                                            };
                                        }
                                        <i class="@methodIcon me-1"></i><small>@methodText</small>
                                    </td>
                                    <td class="fw-semibold text-success">$@p.Amount.ToString("N2")</td>
                                    <td>@p.DueDate.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        @{
                                            var (badgeClass, statusText, statusIcon) = p.Status switch
                                            {
                                                FitManager.Models.PaymentStatus.Paid => ("bg-success", "Pagado", "fas fa-check"),
                                                FitManager.Models.PaymentStatus.Pending => ("bg-warning text-dark", "Pendiente", "fas fa-clock"),
                                                FitManager.Models.PaymentStatus.Overdue => ("bg-danger", "Vencido", "fas fa-exclamation-triangle"),
                                                _ => ("bg-secondary", "Cancelado", "fas fa-ban")
                                            };
                                        }
                                        <span class="badge @badgeClass">
                                            <i class="@statusIcon me-1"></i>@statusText
                                        </span>
                                    </td>
                                    @if (User.IsInRole("Administrador"))
                                    {
                                        <td>
                                            <form asp-action="DeletePayment" method="post" class="confirm-delete-form">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="paymentId" value="@p.Id" />
                                                <input type="hidden" name="memberId" value="@Model.Member.Id" />
                                                <button class="btn btn-sm btn-icon btn-outline-danger" title="Eliminar">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </form>
                                        </td>
                                    }
                                </tr>
                            }
                            @if (!Model.Payments.Any())
                            {
                                <tr>
                                    <td colspan="7" class="text-center py-4 text-muted">
                                        <i class="fas fa-inbox fa-2x mb-2 d-block"></i>
                                        Sin pagos registrados
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- New payment form -->
    <div class="col-lg-4">
        <div class="card fm-card">
            <div class="card-header">
                <h5 class="card-title mb-0"><i class="fas fa-plus-circle me-2 text-accent"></i>Registrar Pago</h5>
            </div>
            <div class="card-body">
                <form asp-action="AddPayment" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="MemberId" value="@Model.Member.Id" />

                    <div class="mb-3">
                        <label class="form-label">Monto <span class="text-accent">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input name="Amount" type="number" step="0.01" min="0" class="form-control"
                                   placeholder="0.00" required />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Descripción</label>
                        <input name="Description" class="form-control" placeholder="Cuota mensual" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Método de Pago</label>
                        <select name="Method" class="form-select">
                            <option value="1"><i class="fas fa-money-bill-wave"></i> Efectivo</option>
                            <option value="2">Tarjeta</option>
                            <option value="3">Transferencia</option>
                            <option value="4">Otro</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Estado</label>
                        <select name="Status" class="form-select">
                            <option value="1">Pagado</option>
                            <option value="2">Pendiente</option>
                            <option value="3">Vencido</option>
                        </select>
                    </div>

                    <div class="row g-2 mb-3">
                        <div class="col">
                            <label class="form-label">Fecha Pago</label>
                            <input name="PaymentDate" type="date" class="form-control"
                                   value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="col">
                            <label class="form-label">Vencimiento</label>
                            <input name="DueDate" type="date" class="form-control"
                                   value="@DateTime.Today.AddMonths(1).ToString("yyyy-MM-dd")" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Nº Recibo</label>
                        <input name="ReceiptNumber" class="form-control" placeholder="Opcional" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Notas</label>
                        <textarea name="Notes" class="form-control" rows="2"></textarea>
                    </div>

                    <button type="submit" class="btn btn-accent w-100">
                        <i class="fas fa-save me-2"></i>Registrar Pago
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
$(document).ready(function () {
    $('#paymentsTable').DataTable({
        language: dtSpanish,
        order: [[0, 'desc']],
        pageLength: 10
    });
    confirmDeleteForms();
});
</script>
}
