@model List<FitManager.ViewModels.MemberPlanAlert>

<div class="card fm-card mb-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-dark table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Socio</th>
                        <th>Nº Socio</th>
                        <th>Plan</th>
                        <th>Vence</th>
                        <th>Días</th>
                        <th class="text-center">Acción</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    @if (!string.IsNullOrEmpty(a.MemberPhoto))
                                    {
                                        <img src="/@a.MemberPhoto" class="rounded-circle" width="32" height="32" style="object-fit:cover" />
                                    }
                                    else
                                    {
                                        <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center" style="width:32px;height:32px">
                                            <i class="fas fa-user text-muted" style="font-size:.7rem"></i>
                                        </div>
                                    }
                                    <strong>@a.MemberName</strong>
                                </div>
                            </td>
                            <td class="text-muted">@a.MemberNumber</td>
                            <td><span class="badge bg-secondary">@a.PlanName</span></td>
                            <td class="text-nowrap">@a.EndDate.ToString("dd/MM/yyyy")</td>
                            <td>
                                @if (a.DaysUntilExpiry < 0)
                                {
                                    <span class="badge bg-danger">Vencido hace @Math.Abs(a.DaysUntilExpiry) días</span>
                                }
                                else if (a.DaysUntilExpiry == 0)
                                {
                                    <span class="badge bg-danger">Hoy</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">@a.DaysUntilExpiry día(s)</span>
                                }
                            </td>
                            <td class="text-center">
                                <a asp-controller="Payments" asp-action="Create"
                                   asp-route-memberId="@a.MemberId"
                                   class="btn btn-sm btn-outline-accent" title="Registrar Renovación">
                                    <i class="fas fa-rotate-right me-1"></i>Renovar
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
