@model FitManager.ViewModels.AlertsViewModel
@{
    ViewData["Title"] = "Alertas de Deuda";
    ViewData["BreadcrumbParent"] = "Cuotas y Pagos";
}

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="fas fa-exclamation-triangle me-2 text-danger"></i>Alertas de Deuda</h1>
        <p class="text-muted mb-0">@Model.OverduePayments.Count socios con pagos pendientes</p>
    </div>
    <div class="page-actions">
        <a asp-action="Expirations" class="btn btn-outline-warning">
            <i class="fas fa-calendar-times me-1"></i>Vencimientos
        </a>
    </div>
</div>

@if (Model.OverduePayments.Any())
{
    <div class="alert alert-danger mb-4">
        <i class="fas fa-exclamation-circle me-2"></i>
        <strong>$@Model.OverduePayments.Sum(d => d.TotalDebt).ToString("N0")</strong>
        en deuda total entre <strong>@Model.OverduePayments.Count</strong> socio(s).
    </div>

    <div class="card fm-card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table id="debtsTable" class="table table-dark table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Socio</th>
                            <th>Nº Socio</th>
                            <th class="text-center">Pagos Vencidos</th>
                            <th>Deuda Total</th>
                            <th>Vencimiento más Antiguo</th>
                            <th>Días de Mora</th>
                            <th class="text-center">Acción</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in Model.OverduePayments)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        @if (!string.IsNullOrEmpty(d.MemberPhoto))
                                        {
                                            <img src="/@d.MemberPhoto" class="rounded-circle" width="32" height="32" style="object-fit:cover" />
                                        }
                                        else
                                        {
                                            <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center" style="width:32px;height:32px">
                                                <i class="fas fa-user text-muted" style="font-size:.7rem"></i>
                                            </div>
                                        }
                                        <a asp-controller="Members" asp-action="Payments" asp-route-id="@d.MemberId"
                                           class="text-decoration-none fw-bold">@d.MemberName</a>
                                    </div>
                                </td>
                                <td class="text-muted">@d.MemberNumber</td>
                                <td class="text-center">
                                    <span class="badge bg-danger rounded-pill">@d.OverdueCount</span>
                                </td>
                                <td><strong class="text-danger">$@d.TotalDebt.ToString("N0")</strong></td>
                                <td class="text-nowrap text-muted">@d.OldestDueDate.ToString("dd/MM/yyyy")</td>
                                <td>
                                    @if (d.DaysOverdue > 30)
                                    {
                                        <span class="badge bg-danger">@d.DaysOverdue días</span>
                                    }
                                    else if (d.DaysOverdue > 0)
                                    {
                                        <span class="badge bg-warning text-dark">@d.DaysOverdue días</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Hoy</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <a asp-controller="Payments" asp-action="Create" asp-route-memberId="@d.MemberId"
                                       class="btn btn-sm btn-outline-success" title="Registrar pago">
                                        <i class="fas fa-dollar-sign me-1"></i>Cobrar
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
else
{
    <div class="card fm-card text-center py-5">
        <i class="fas fa-check-circle fa-3x text-success mb-3"></i>
        <h5>¡Sin deudas!</h5>
        <p class="text-muted">No hay socios con pagos vencidos o pendientes.</p>
    </div>
}

@section Scripts {
<script>
    $('#debtsTable')?.DataTable({
        language: { url: 'https://cdn.datatables.net/plug-ins/1.13.8/i18n/es-ES.json' },
        order: [[5, 'desc']],
        pageLength: 25
    });
</script>
}
