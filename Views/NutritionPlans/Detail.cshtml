@model FitManager.ViewModels.NutritionPlanDetailViewModel
@using FitManager.Models
@{
    ViewData["Title"] = Model.NutritionPlan.Name;
    ViewData["BreadcrumbParent"] = "Nutrición";
    var p = Model.NutritionPlan;
}

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="fas fa-leaf me-2 text-accent"></i>@p.Name</h1>
        <p class="text-muted mb-0">@Model.GoalLabel — @Model.DurationLabel</p>
    </div>
    <div class="page-actions d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>Volver</a>
        <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-outline-warning">
            <i class="fas fa-edit me-1"></i>Editar
        </a>
        <a asp-controller="MemberNutrition" asp-action="Assign" class="btn btn-outline-success">
            <i class="fas fa-user-plus me-1"></i>Asignar a Socio
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-4">
    <!-- Info general -->
    <div class="col-lg-4">
        <div class="card fm-card h-100">
            <div class="card-header">
                <h5 class="card-title mb-0"><i class="fas fa-info-circle me-2 text-accent"></i>Información</h5>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-5 text-muted">Objetivo</dt>
                    <dd class="col-7"><span class="badge bg-dark border border-secondary">@Model.GoalLabel</span></dd>
                    <dt class="col-5 text-muted">Duración</dt>
                    <dd class="col-7">@Model.DurationLabel</dd>
                    <dt class="col-5 text-muted">Tipo</dt>
                    <dd class="col-7">
                        @if (p.IsTemplate)
                        {
                            <span class="badge bg-primary"><i class="fas fa-clone me-1"></i>Plantilla</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark"><i class="fas fa-user me-1"></i>Personalizado</span>
                        }
                    </dd>
                    <dt class="col-5 text-muted">Estado</dt>
                    <dd class="col-7">
                        @if (p.IsActive)
                        {
                            <span class="badge bg-success">Activo</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactivo</span>
                        }
                    </dd>
                    <dt class="col-5 text-muted">Comidas</dt>
                    <dd class="col-7"><span class="badge bg-info">@p.Meals.Count</span></dd>
                </dl>

                @if (!string.IsNullOrWhiteSpace(p.Description))
                {
                    <hr class="border-secondary" />
                    <p class="text-muted small mb-0">@p.Description</p>
                }

                @if (!string.IsNullOrWhiteSpace(p.GeneralNotes))
                {
                    <hr class="border-secondary" />
                    <div class="d-flex gap-2 align-items-start">
                        <i class="fas fa-lightbulb text-warning mt-1 flex-shrink-0"></i>
                        <div>
                            <div class="small text-muted mb-1 fw-bold">Recomendaciones</div>
                            <p class="small mb-0" style="white-space:pre-line;">@p.GeneralNotes</p>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Comidas -->
    <div class="col-lg-8">
        @if (!p.Meals.Any())
        {
            <div class="card fm-card">
                <div class="card-body text-center text-muted py-5">
                    <i class="fas fa-utensils fa-3x mb-3 d-block opacity-40"></i>
                    <p class="mb-2">Este plan no tiene comidas configuradas.</p>
                    <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-accent">
                        <i class="fas fa-edit me-1"></i>Agregar Comidas
                    </a>
                </div>
            </div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var meal in p.Meals.OrderBy(m => m.OrderIndex))
                {
                    var icon = meal.MealType switch
                    {
                        MealType.Breakfast      => "fas fa-sun",
                        MealType.MorningSnack   => "fas fa-apple-alt",
                        MealType.Lunch          => "fas fa-utensils",
                        MealType.AfternoonSnack => "fas fa-coffee",
                        MealType.Dinner         => "fas fa-moon",
                        MealType.EveningSnack   => "fas fa-cookie",
                        _                       => "fas fa-bowl-food"
                    };
                    var mealLabel = meal.MealType switch
                    {
                        MealType.Breakfast      => "Desayuno",
                        MealType.MorningSnack   => "Colación Mañana",
                        MealType.Lunch          => "Almuerzo",
                        MealType.AfternoonSnack => "Merienda",
                        MealType.Dinner         => "Cena",
                        MealType.EveningSnack   => "Colación Noche",
                        _                       => "Comida"
                    };

                    <div class="col-md-6">
                        <div class="card fm-card h-100">
                            <div class="card-header d-flex align-items-center gap-2"
                                 style="background:rgba(255,255,255,.05);">
                                <i class="@icon text-accent"></i>
                                <span class="fw-semibold">
                                    @(string.IsNullOrWhiteSpace(meal.CustomName) ? mealLabel : meal.CustomName)
                                </span>
                                @if (!string.IsNullOrWhiteSpace(meal.CustomName))
                                {
                                    <span class="text-muted small ms-1">(@mealLabel)</span>
                                }
                            </div>
                            <div class="card-body py-2 px-3">
                                @if (!string.IsNullOrWhiteSpace(meal.Content))
                                {
                                    <p class="mb-1" style="white-space:pre-line; font-size:.9rem;">@meal.Content</p>
                                }
                                @if (!string.IsNullOrWhiteSpace(meal.Quantities))
                                {
                                    <p class="text-muted small mb-1">
                                        <i class="fas fa-balance-scale me-1"></i>@meal.Quantities
                                    </p>
                                }
                                @if (!string.IsNullOrWhiteSpace(meal.Notes))
                                {
                                    <p class="text-muted small mb-0">
                                        <i class="fas fa-sticky-note me-1"></i>@meal.Notes
                                    </p>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
