@model FitManager.ViewModels.CashRegisterDetailViewModel?
@using FitManager.Models
@using FitManager.ViewModels
@{
    ViewData["Title"] = "Caja Diaria";
    ViewData["BreadcrumbParent"] = "Cuotas y Pagos";
    var isOpen = Model?.Register.Status == CashRegisterStatus.Open;
}

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="fas fa-cash-register me-2 text-accent"></i>Caja Diaria</h1>
        <p class="text-muted mb-0">@DateTime.Today.ToString("dddd, dd 'de' MMMM 'de' yyyy", new System.Globalization.CultureInfo("es-AR"))</p>
    </div>
    <div class="page-actions">
        <a asp-action="History" class="btn btn-outline-secondary">
            <i class="fas fa-history me-1"></i>Historial
        </a>
    </div>
</div>

@if (Model == null)
{
    <!-- No hay caja abierta hoy -->
    <div class="row justify-content-center mt-4">
        <div class="col-lg-5">
            <div class="card fm-card text-center">
                <div class="card-body py-5">
                    <i class="fas fa-cash-register fa-4x text-muted mb-4"></i>
                    <h4>No hay caja abierta hoy</h4>
                    <p class="text-muted mb-4">Abrí la caja para empezar a registrar los ingresos del día.</p>
                    <button type="button" class="btn btn-accent btn-lg" data-bs-toggle="modal" data-bs-target="#openModal">
                        <i class="fas fa-lock-open me-2"></i>Abrir Caja
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal abrir caja -->
    <div class="modal fade" id="openModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content bg-dark">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title"><i class="fas fa-lock-open me-2 text-accent"></i>Abrir Caja del Día</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <form asp-action="Open" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Saldo inicial (efectivo en caja)</label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input type="number" name="OpeningBalance" class="form-control" value="0" min="0" step="0.01" />
                            </div>
                            <small class="text-muted">Ingresá el efectivo que hay en la caja al inicio del día.</small>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Notas</label>
                            <textarea name="Notes" class="form-control" rows="2" placeholder="Observaciones..."></textarea>
                        </div>
                    </div>
                    <div class="modal-footer border-secondary">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-accent">
                            <i class="fas fa-lock-open me-2"></i>Abrir Caja
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}
else
{
    var r = Model.Register;

    <!-- Estado de la caja -->
    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-lg-3">
            <div class="card fm-card border-success h-100">
                <div class="card-body">
                    <div class="text-muted small mb-1">Saldo Inicial</div>
                    <div class="h4 text-success mb-0">$@r.OpeningBalance.ToString("N0")</div>
                    <small class="text-muted">Apertura @r.OpenedAt.ToString("HH:mm")</small>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="card fm-card border-accent h-100">
                <div class="card-body">
                    <div class="text-muted small mb-1">Cobros del Día</div>
                    <div class="h4 text-accent mb-0">$@Model.PaymentsTotal.ToString("N0")</div>
                    <small class="text-muted">@Model.Payments.Count pago(s)</small>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="card fm-card h-100">
                <div class="card-body">
                    <div class="text-muted small mb-1">Ing. Extra / Egresos</div>
                    <div class="h5 mb-0">
                        <span class="text-success">+$@Model.ManualIncome.ToString("N0")</span>
                        <span class="text-muted mx-1">/</span>
                        <span class="text-danger">-$@Model.ManualExpense.ToString("N0")</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="card fm-card @(isOpen ? "border-warning" : "border-secondary") h-100">
                <div class="card-body">
                    <div class="text-muted small mb-1">Balance Neto</div>
                    <div class="h4 mb-1">$@Model.NetBalance.ToString("N0")</div>
                    @if (isOpen)
                    {
                        <span class="badge bg-warning text-dark"><i class="fas fa-circle me-1"></i>Caja Abierta</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary"><i class="fas fa-lock me-1"></i>Caja Cerrada</span>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Cobros -->
        <div class="col-lg-7">
            <div class="card fm-card h-100">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h6 class="mb-0"><i class="fas fa-money-bill-wave me-2 text-success"></i>Cobros del Día</h6>
                    @if (isOpen)
                    {
                        <a asp-controller="Payments" asp-action="Create" class="btn btn-sm btn-outline-success">
                            <i class="fas fa-plus me-1"></i>Nuevo Pago
                        </a>
                    }
                </div>
                <div class="card-body p-0">
                    @if (Model.Payments.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-dark table-hover mb-0 align-middle">
                                <thead><tr>
                                    <th>Hora</th><th>Socio</th><th>Plan/Concepto</th><th>Método</th><th class="text-end">Monto</th>
                                </tr></thead>
                                <tbody>
                                    @foreach (var p in Model.Payments.OrderBy(x => x.PaymentDate))
                                    {
                                        <tr>
                                            <td class="text-muted small">@p.PaymentDate.ToString("HH:mm")</td>
                                            <td>@p.Member?.FullName</td>
                                            <td>@(p.Plan?.Name ?? p.Description)</td>
                                            <td>
                                                @switch (p.Method)
                                                {
                                                    case PaymentMethod.Cash: <span class="badge bg-success">Efectivo</span> break;
                                                    case PaymentMethod.Card: <span class="badge bg-primary">Tarjeta</span> break;
                                                    case PaymentMethod.Transfer: <span class="badge bg-info">Transfer.</span> break;
                                                    default: <span class="badge bg-secondary">Otro</span> break;
                                                }
                                            </td>
                                            <td class="text-end text-accent fw-bold">$@p.Amount.ToString("N0")</td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot>
                                    <tr class="fw-bold">
                                        <td colspan="4" class="text-end">TOTAL</td>
                                        <td class="text-end text-accent">$@Model.PaymentsTotal.ToString("N0")</td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                        <!-- Desglose por método -->
                        <div class="p-3 border-top border-secondary">
                            <div class="row g-2 text-center small">
                                <div class="col-3">
                                    <div class="text-muted">Efectivo</div>
                                    <div class="text-success fw-bold">$@Model.PaymentsCash.ToString("N0")</div>
                                </div>
                                <div class="col-3">
                                    <div class="text-muted">Tarjeta</div>
                                    <div class="text-primary fw-bold">$@Model.PaymentsCard.ToString("N0")</div>
                                </div>
                                <div class="col-3">
                                    <div class="text-muted">Transfer.</div>
                                    <div class="text-info fw-bold">$@Model.PaymentsTransfer.ToString("N0")</div>
                                </div>
                                <div class="col-3">
                                    <div class="text-muted">Otro</div>
                                    <div class="fw-bold">$@Model.PaymentsOther.ToString("N0")</div>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-4">
                            <i class="fas fa-inbox fa-2x mb-2 d-block"></i>
                            No hay cobros registrados hoy.
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Panel derecho: transacciones manuales + cierre -->
        <div class="col-lg-5">
            <!-- Transacciones manuales -->
            <div class="card fm-card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h6 class="mb-0"><i class="fas fa-exchange-alt me-2"></i>Movimientos Manuales</h6>
                    @if (isOpen)
                    {
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#transactionModal">
                            <i class="fas fa-plus me-1"></i>Agregar
                        </button>
                    }
                </div>
                <div class="card-body p-0">
                    @if (Model.Transactions.Any())
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var t in Model.Transactions)
                            {
                                <li class="list-group-item list-group-item-dark d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="small fw-bold">@t.Description</div>
                                        <div class="text-muted" style="font-size:.75rem">@t.CreatedAt.ToString("HH:mm") — @t.CreatedBy</div>
                                    </div>
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="@(t.Type == TransactionType.Income ? "text-success" : t.Type == TransactionType.Expense ? "text-danger" : "text-warning") fw-bold">
                                            @(t.Type == TransactionType.Expense ? "-" : "+")$@t.Amount.ToString("N0")
                                        </span>
                                        @if (isOpen)
                                        {
                                            <form method="post" asp-action="DeleteTransaction" style="display:inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@t.Id" />
                                                <input type="hidden" name="registerId" value="@r.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger py-0 px-1">
                                                    <i class="fas fa-times" style="font-size:.7rem"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="text-center text-muted py-3 small">Sin movimientos manuales.</div>
                    }
                </div>
            </div>

            <!-- Cierre de caja -->
            @if (isOpen)
            {
                <div class="card fm-card border-warning">
                    <div class="card-header border-warning">
                        <h6 class="mb-0 text-warning"><i class="fas fa-lock me-2"></i>Cerrar Caja</h6>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <div class="d-flex justify-content-between text-muted small mb-1">
                                <span>Balance calculado:</span>
                                <strong class="text-white">$@Model.NetBalance.ToString("N0")</strong>
                            </div>
                        </div>
                        <button type="button" class="btn btn-warning w-100" data-bs-toggle="modal" data-bs-target="#closeModal">
                            <i class="fas fa-lock me-2"></i>Cerrar Caja del Día
                        </button>
                    </div>
                </div>
            }
            else
            {
                <div class="card fm-card border-secondary">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <h6 class="text-muted mb-0"><i class="fas fa-lock me-2"></i>Caja Cerrada</h6>
                            @if (r.WasReopened)
                            {
                                <span class="badge bg-warning text-dark"><i class="fas fa-rotate-right me-1"></i>Reabierta previamente</span>
                            }
                        </div>
                        @if (r.ClosingBalance.HasValue)
                        {
                            <div class="d-flex justify-content-between small mb-1">
                                <span class="text-muted">Balance calculado:</span>
                                <span>$@Model.NetBalance.ToString("N0")</span>
                            </div>
                            <div class="d-flex justify-content-between small mb-1">
                                <span class="text-muted">Saldo final real:</span>
                                <strong>$@r.ClosingBalance.Value.ToString("N0")</strong>
                            </div>
                            @if (Model.Discrepancy != 0)
                            {
                                <div class="d-flex justify-content-between small mb-1">
                                    <span class="text-muted">Diferencia:</span>
                                    <span class="@(Model.Discrepancy > 0 ? "text-success" : "text-danger") fw-bold">
                                        @(Model.Discrepancy > 0 ? "+" : "")$@Model.Discrepancy.ToString("N0")
                                    </span>
                                </div>
                            }
                            <hr class="border-secondary my-2" />
                            <small class="text-muted d-block mb-3">
                                Cerrada @r.ClosedAt?.ToString("HH:mm") por @r.ClosedBy
                            </small>
                        }
                        @if (r.WasReopened && r.ReopenNotes != null)
                        {
                            <div class="alert alert-warning py-2 small mb-3">
                                <i class="fas fa-rotate-right me-1"></i>
                                <strong>Motivo reapertura anterior:</strong> @r.ReopenNotes
                                <span class="text-muted ms-1">(@r.ReopenedBy · @r.ReopenedAt?.ToString("HH:mm"))</span>
                            </div>
                        }
                        @if (User.IsInRole("Administrador"))
                        {
                            <button type="button" class="btn btn-outline-warning w-100"
                                    data-bs-toggle="modal" data-bs-target="#reopenModal">
                                <i class="fas fa-lock-open me-2"></i>Reabrir Caja de Hoy
                            </button>
                        }
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Modal: agregar transacción manual -->
    @if (isOpen)
    {
        <div class="modal fade" id="transactionModal" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content bg-dark">
                    <div class="modal-header border-secondary">
                        <h5 class="modal-title"><i class="fas fa-exchange-alt me-2"></i>Movimiento Manual</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <form asp-action="AddTransaction" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="CashRegisterId" value="@r.Id" />
                        <div class="modal-body">
                            <div class="row g-3">
                                <div class="col-6">
                                    <label class="form-label">Tipo</label>
                                    <select name="Type" class="form-select">
                                        <option value="1">Ingreso</option>
                                        <option value="2">Egreso</option>
                                        <option value="3">Ajuste</option>
                                    </select>
                                </div>
                                <div class="col-6">
                                    <label class="form-label">Monto</label>
                                    <div class="input-group">
                                        <span class="input-group-text">$</span>
                                        <input type="number" name="Amount" class="form-control" min="0.01" step="0.01" required />
                                    </div>
                                </div>
                            </div>
                            <div class="mt-3">
                                <label class="form-label">Descripción</label>
                                <input type="text" name="Description" class="form-control" required maxlength="200" placeholder="Ej: Compra de materiales de limpieza" />
                            </div>
                            <div class="mt-3">
                                <label class="form-label">Notas (opcional)</label>
                                <textarea name="Notes" class="form-control" rows="2"></textarea>
                            </div>
                        </div>
                        <div class="modal-footer border-secondary">
                            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                            <button type="submit" class="btn btn-accent">
                                <i class="fas fa-save me-2"></i>Registrar
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Modal: cerrar caja -->
        <div class="modal fade" id="closeModal" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content bg-dark">
                    <div class="modal-header border-warning">
                        <h5 class="modal-title text-warning"><i class="fas fa-lock me-2"></i>Cerrar Caja</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <form asp-action="Close" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="RegisterId" value="@r.Id" />
                        <input type="hidden" name="CalculatedBalance" value="@Model.NetBalance" />
                        <div class="modal-body">
                            <div class="alert alert-dark border border-secondary mb-3">
                                <div class="d-flex justify-content-between">
                                    <span>Balance calculado del sistema:</span>
                                    <strong>$@Model.NetBalance.ToString("N0")</strong>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Saldo real en caja (conteo físico)</label>
                                <div class="input-group">
                                    <span class="input-group-text">$</span>
                                    <input type="number" name="ClosingBalance" class="form-control form-control-lg"
                                           value="@Model.NetBalance" min="0" step="0.01" id="closingBalanceInput" />
                                </div>
                            </div>
                            <div id="discrepancyAlert" class="alert d-none"></div>
                            <div class="mb-3">
                                <label class="form-label">Notas de cierre</label>
                                <textarea name="Notes" class="form-control" rows="2" placeholder="Observaciones..."></textarea>
                            </div>
                        </div>
                        <div class="modal-footer border-secondary">
                            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                            <button type="submit" class="btn btn-warning">
                                <i class="fas fa-lock me-2"></i>Confirmar Cierre
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }

    <!-- Modal: reabrir caja (solo Administrador, caja cerrada) -->
    @if (!isOpen && User.IsInRole("Administrador"))
    {
        <div class="modal fade" id="reopenModal" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content bg-dark">
                    <div class="modal-header border-warning">
                        <h5 class="modal-title text-warning">
                            <i class="fas fa-lock-open me-2"></i>Reabrir Caja
                        </h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <form asp-action="Reopen" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="RegisterId" value="@Model!.Register.Id" />
                        <div class="modal-body">
                            <div class="alert alert-warning py-2 small mb-3">
                                <i class="fas fa-triangle-exclamation me-1"></i>
                                La caja se reabrirá. El saldo de cierre anterior quedará en el historial de auditoría.
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">
                                    Motivo <span class="text-danger">*</span>
                                </label>
                                <textarea name="Reason" class="form-control" rows="3" required maxlength="500"
                                          placeholder="Ej: Cierre accidental, corrección de cobro faltante…"></textarea>
                                <div class="form-text text-muted">Queda registrado en el historial junto a tu usuario.</div>
                            </div>
                        </div>
                        <div class="modal-footer border-secondary">
                            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                            <button type="submit" class="btn btn-warning">
                                <i class="fas fa-lock-open me-2"></i>Confirmar Reapertura
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }
}

@section Scripts {
<script>
    const netBalance = @(Model == null ? "0" : Model.NetBalance.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture));

    const inp = document.getElementById('closingBalanceInput');
    const alertDiv = document.getElementById('discrepancyAlert');
    if (inp) {
        inp.addEventListener('input', function () {
            const diff = parseFloat(this.value || 0) - netBalance;
            if (Math.abs(diff) > 0.01) {
                alertDiv.className = 'alert ' + (diff > 0 ? 'alert-success' : 'alert-danger');
                alertDiv.textContent = (diff > 0 ? 'Sobrante: +$' : 'Faltante: -$') + Math.abs(diff).toFixed(2);
                alertDiv.classList.remove('d-none');
            } else {
                alertDiv.classList.add('d-none');
            }
        });
    }
</script>
}
