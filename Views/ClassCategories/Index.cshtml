@model List<FitManager.ViewModels.ClassCategoryViewModel>
@{
    ViewData["Title"] = "Categorías de Clases";
    ViewData["BreadcrumbParent"] = "Clases";
}

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="fas fa-tags me-2 text-accent"></i>Categorías de Clases</h1>
        <p class="text-muted mb-0">Administrá las categorías disponibles para las clases</p>
    </div>
    <div class="page-actions">
        <a asp-action="Create" class="btn btn-accent">
            <i class="fas fa-plus me-1"></i>Nueva Categoría
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
        <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card fm-card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table id="categoriesTable" class="table table-hover fm-table mb-0">
                <thead>
                    <tr>
                        <th>Categoría</th>
                        <th>Descripción</th>
                        <th class="text-center">Orden</th>
                        <th class="text-center">Clases</th>
                        <th class="text-center">Estado</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cat in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="rounded-circle flex-shrink-0"
                                          style="width:14px;height:14px;background-color:@cat.Color;display:inline-block;"></span>
                                    <span class="me-1" style="color:@cat.Color;">
                                        <i class="fas @cat.Icon"></i>
                                    </span>
                                    <span class="fw-semibold">@cat.Name</span>
                                </div>
                            </td>
                            <td class="text-muted small">@(cat.Description ?? "—")</td>
                            <td class="text-center">
                                <span class="badge bg-dark border border-secondary">@cat.OrderIndex</span>
                            </td>
                            <td class="text-center">
                                <span class="badge @(cat.ClassCount > 0 ? "bg-info" : "bg-dark border border-secondary")">
                                    @cat.ClassCount
                                </span>
                            </td>
                            <td class="text-center">
                                @if (cat.IsActive)
                                {
                                    <span class="badge badge-status bg-success">
                                        <i class="fas fa-circle me-1" style="font-size:.5rem;"></i>Activa
                                    </span>
                                }
                                else
                                {
                                    <span class="badge badge-status bg-secondary">
                                        <i class="fas fa-circle me-1" style="font-size:.5rem;"></i>Inactiva
                                    </span>
                                }
                            </td>
                            <td>
                                <div class="d-flex justify-content-center gap-1">
                                    <a asp-action="Edit" asp-route-id="@cat.Id"
                                       class="btn btn-sm btn-icon btn-outline-warning" title="Editar">
                                        <i class="fas fa-edit"></i>
                                    </a>

                                    <!-- Toggle active -->
                                    <form asp-action="ToggleActive" asp-route-id="@cat.Id"
                                          method="post" class="d-inline toggle-form">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="btn btn-sm btn-icon @(cat.IsActive ? "btn-outline-secondary" : "btn-outline-success")"
                                                title="@(cat.IsActive ? "Desactivar" : "Activar")">
                                            <i class="fas @(cat.IsActive ? "fa-toggle-off" : "fa-toggle-on")"></i>
                                        </button>
                                    </form>

                                    <!-- Delete -->
                                    @if (cat.ClassCount == 0)
                                    {
                                        <form asp-action="Delete" asp-route-id="@cat.Id"
                                              method="post" class="d-inline delete-form">
                                            @Html.AntiForgeryToken()
                                            <button type="button"
                                                    class="btn btn-sm btn-icon btn-outline-danger btn-delete"
                                                    title="Eliminar"
                                                    data-name="@cat.Name">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-icon btn-outline-danger" disabled
                                                title="Tiene clases asociadas">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
$(document).ready(function () {
    $('#categoriesTable').DataTable({
        language: dtSpanish,
        pageLength: 25,
        order: [[2, 'asc']],
        columnDefs: [{ orderable: false, targets: [5] }]
    });

    $(document).on('click', '.btn-delete', function () {
        const btn  = $(this);
        const name = btn.data('name');
        const form = btn.closest('.delete-form');
        Swal.fire({
            title: '¿Eliminar categoría?',
            html: `¿Eliminás <strong>${name}</strong>?<br><small class="text-muted">Solo se puede eliminar si no tiene clases asociadas.</small>`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#dc3545',
            cancelButtonColor: '#6c757d',
            confirmButtonText: '<i class="fas fa-trash me-1"></i>Sí, eliminar',
            cancelButtonText: 'Cancelar',
            background: '#1a1d27',
            color: '#e0e0e0'
        }).then(result => {
            if (result.isConfirmed) form.submit();
        });
    });
});
</script>
}
