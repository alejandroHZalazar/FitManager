@model FitManager.ViewModels.ClassCategoryViewModel
@{
    ViewData["Title"] = $"Editar: {Model.Name}";
    ViewData["BreadcrumbParent"] = "Categorías de Clases";
}

<div class="page-header">
    <div>
        <h1 class="page-title">
            <i class="fas fa-edit me-2 text-accent"></i>Editar:
            <span class="text-accent">@Model.Name</span>
        </h1>
    </div>
    <div class="page-actions">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i>Volver
        </a>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card fm-card">
            <div class="card-header">
                <h5 class="card-title mb-0"><i class="fas fa-tag me-2 text-accent"></i>Datos de la Categoría</h5>
            </div>
            <div class="card-body">
                <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

                    <!-- Name -->
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Nombre <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" placeholder="Ej. Yoga, Spinning..." required />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <!-- Description -->
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Descripción</label>
                        <textarea asp-for="Description" class="form-control" rows="2"
                                  placeholder="Descripción breve..."></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <!-- Color + Order -->
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label asp-for="Color" class="form-label">Color</label>
                            <div class="input-group">
                                <span class="input-group-text p-1">
                                    <input type="color" id="colorPicker" value="@Model.Color"
                                           style="width:32px;height:32px;border:none;cursor:pointer;background:transparent;" />
                                </span>
                                <input asp-for="Color" class="form-control font-monospace" id="colorText"
                                       placeholder="#6c757d" maxlength="7" />
                            </div>
                        </div>
                        <div class="col-6">
                            <label asp-for="OrderIndex" class="form-label">Orden</label>
                            <input asp-for="OrderIndex" class="form-control" type="number" min="1" max="999" />
                        </div>
                    </div>

                    <!-- Icon picker -->
                    <div class="mb-3">
                        <label class="form-label">Ícono</label>
                        <input asp-for="Icon" type="hidden" id="iconValue" />

                        <!-- Selected icon display -->
                        <div class="d-flex align-items-center gap-3 p-3 rounded mb-2"
                             style="background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);">
                            <span id="selectedIconDisplay"
                                  class="rounded d-flex align-items-center justify-content-center flex-shrink-0"
                                  style="width:48px;height:48px;font-size:1.4rem;background:rgba(255,255,255,.08);">
                                <i id="selectedIconEl" class="fas @Model.Icon"></i>
                            </span>
                            <div class="flex-grow-1">
                                <div class="fw-semibold" id="selectedIconName">@Model.Icon</div>
                                <div class="text-muted small">Ícono seleccionado</div>
                            </div>
                            <button type="button" class="btn btn-sm btn-outline-secondary" id="btnOpenPicker">
                                <i class="fas fa-th me-1"></i>Cambiar
                            </button>
                        </div>

                        <!-- Icon picker panel -->
                        <div id="iconPickerPanel" class="d-none rounded p-3"
                             style="background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);">
                            <div class="mb-2">
                                <div class="input-group input-group-sm">
                                    <span class="input-group-text"><i class="fas fa-search"></i></span>
                                    <input type="text" id="iconSearch" class="form-control"
                                           placeholder="Buscar ícono..." autocomplete="off" />
                                </div>
                            </div>
                            <div id="iconGrid"
                                 style="display:grid;grid-template-columns:repeat(auto-fill,minmax(52px,1fr));gap:6px;max-height:260px;overflow-y:auto;">
                            </div>
                        </div>
                    </div>

                    <!-- Preview badge -->
                    <div class="mb-4 p-3 rounded" style="background:rgba(255,255,255,.04);">
                        <div class="text-muted small mb-2">Vista previa</div>
                        <span id="previewBadge" class="badge fs-6 px-3 py-2"
                              style="background-color:@Model.Color;">
                            <i id="previewIcon" class="fas @Model.Icon me-1"></i>
                            <span id="previewName">@Model.Name</span>
                        </span>
                    </div>

                    <!-- IsActive -->
                    <div class="mb-4 form-check form-switch">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" />
                        <label asp-for="IsActive" class="form-check-label">Activa</label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-accent">
                            <i class="fas fa-save me-1"></i>Guardar Cambios
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
@await Html.PartialAsync("_IconPickerScript", Model.Icon)
}
